---
let temperature: string = "---";
try {
  const weatherResponse = await fetch('https://api.open-meteo.com/v1/forecast?latitude=51.5136&longitude=7.4653&current_weather=true');
  if (weatherResponse.ok) {
    const weatherData = await weatherResponse.json();
    temperature = `${weatherData.current_weather.temperature}°C`;
  }
} catch (error) {
  console.error("Error fetching weather metrics:", error);
}
---
<p class="text-zinc-500 text-xs">
  It is currently <span class="text-zinc-300">{temperature}</span> where I live near Dortmund.
</p>