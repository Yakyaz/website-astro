---
const githubUsername = "Yakyaz";
const token = import.meta.env.GITHUB_TOKEN; 

interface ContributionDay {
  date: string;
  contributionCount: number;
  contributionLevel: 'NONE' | 'FIRST_QUARTILE' | 'SECOND_QUARTILE' | 'THIRD_QUARTILE' | 'FOURTH_QUARTILE';
}

let contributions: ContributionDay[] = [];

const query = `
  query($username: String!) {
    user(login: $username) {
      contributionsCollection {
        contributionCalendar {
          weeks {
            contributionDays {
              date
              contributionCount
              contributionLevel
            }
          }
        }
      }
    }
  }
`;

if (token) {
  try {
    const response = await fetch("https://api.github.com/graphql", {
      method: "POST",
      headers: {
        "Authorization": `Bearer ${token}`,
        "Content-Type": "application/json",
        "User-Agent": "Astro-Portfolio"
      },
      body: JSON.stringify({
        query,
        variables: { username: githubUsername }
      })
    });

    if (response.ok) {
      const json = await response.json();
      const weeks = json.data?.user?.contributionsCollection?.contributionCalendar?.weeks || [];
      
      contributions = weeks.flatMap((week: any) => week.contributionDays);
    }
  } catch (error) {
    console.error("Error fetching GitHub GraphQL data:", error);
  }
}

const getColorClass = (level: string) => {
  switch (level) {
    case 'FIRST_QUARTILE': return 'bg-purple-900';
    case 'SECOND_QUARTILE': return 'bg-purple-700';
    case 'THIRD_QUARTILE': return 'bg-purple-500';
    case 'FOURTH_QUARTILE': return 'bg-purple-300';
    default: return 'bg-zinc-900';
  }
};
---
<div class="flex flex-col gap-2 text-xs text-zinc-500">
  <div class="mb-2">GitHub</div>
  <div class="w-full overflow-x-auto pb-2">
    <div class="grid grid-flow-col grid-rows-7 gap-[3px] min-w-[650px] w-max">
      {contributions.map((day) => (
        <div 
          class={`w-[10px] h-[10px] rounded-[2px] transition-colors ${getColorClass(day.contributionLevel)}`}
          title={`${day.date}: ${day.contributionCount} contributions`}
        ></div>
      ))}
    </div>
  </div>
</div>